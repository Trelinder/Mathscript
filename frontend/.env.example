# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  The Math Script — Frontend Environment Variables                           │
# │  Copy this file to .env (or .env.local) and adjust values as needed.        │
# │                                                                              │
# │  PRODUCTION (Azure App Service)                                              │
# │  ─────────────────────────────                                               │
# │  For runtime toggling without redeployment, set Application Settings with   │
# │  the same names (Vite prefix included).  The app reads them from             │
# │  window.__FEATURE_FLAGS__ which can be injected via a startup script or      │
# │  index.html template substitution.                                            │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Feature Flags ─────────────────────────────────────────────────────────────
# All flags default to false (off) for safety.
# Set to "true" to enable in any environment.

# "The Concrete Packers" — drag-and-drop addition/place-value game (age 5–7)
VITE_FEATURE_CONCRETE_PACKERS=false

# "Potion Alchemists" — fraction equivalence pouring game (age 8–11)
VITE_FEATURE_POTION_ALCHEMISTS=false

# ── Firebase Web Config ────────────────────────────────────────────────────────
# Copy these values from Firebase Console → Project Settings → Your apps → SDK setup.
# These are NOT secrets — they are safe to include in the built JS bundle.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=themathscript-86437.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=themathscript-86437
VITE_FIREBASE_STORAGE_BUCKET=themathscript-86437.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
