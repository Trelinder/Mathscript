[Unit]
Description=MathScript FastAPI Backend
After=network.target postgresql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/Mathscript
EnvironmentFile=/home/ubuntu/Mathscript/.env
ExecStart=/home/ubuntu/Mathscript/venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 5000 --workers 2
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mathscript

[Install]
WantedBy=multi-user.target
